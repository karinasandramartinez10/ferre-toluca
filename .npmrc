# Supply-chain hardening
# Wait 3 days before installing a newly published version.
# Mitigates Shai-Hulud-style attacks where a compromised version is
# yanked from npm within ~72h of publication.
# IMPORTANT: this is npm 11+ syntax — Node 24 (npm 11+) required.
min-release-age=3

# Block install lifecycle scripts (primary RCE vector for supply chain
# worms like Mini Shai-Hulud). Devs run `npm run setup` after clone to
# install husky hooks explicitly.
ignore-scripts=true

fund=false
package-lock=true
